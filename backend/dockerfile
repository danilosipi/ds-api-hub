# build
FROM node:22-alpine AS builder

# Atualiza pacotes do SO (Alpine) para reduzir CVEs reportados pelo scanner na imagem base.
RUN apk update && apk upgrade --no-cache

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

# runtime
FROM node:22-alpine

RUN apk update && apk upgrade --no-cache

WORKDIR /app

ENV NODE_ENV=production

COPY package*.json ./
RUN npm ci --omit=dev

COPY --from=builder /app/dist ./dist

EXPOSE 3001

CMD ["node", "dist/main.js"]
