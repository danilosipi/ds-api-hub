# URL base do backend principal (Minha Agenda) que recebe eventos normalizados.
# POST: {PROCESSOR_API_URL}/whatsapp/webhook
PROCESSOR_API_URL=http://localhost:3000

# Multi-tenant: mapeamento phone_number_id (Cloud API) / número exibido → account_id do Minha Agenda.
# Ex.: [{"phone_number_id":"123456789","account_id":"uuid-da-conta","display_phone_number":"5511999999999"}]
WHATSAPP_INTEGRATIONS_JSON=

# Opcional (legado, single-tenant): usado só se não houver match em WHATSAPP_INTEGRATIONS_JSON.
# PROCESSOR_ACCOUNT_ID=dev-account

# Token de verificação do webhook (WhatsApp Cloud API / Meta).
# Deve ser o mesmo valor configurado no painel da Meta ao registrar a URL de callback.
META_WEBHOOK_VERIFY_TOKEN=dstudium_token

# OAuth / Embedded Signup (troca de code por access token na Graph API).
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=https://api.dstudium.com/oauth/meta/callback

# Porta HTTP (opcional; padrão 3001)
# PORT=3001
